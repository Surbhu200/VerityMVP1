DATABASE_URL="postgresql://postgres:postgres@localhost:5432/research_marketplace?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"

# AI curation
# Use Ollama locally now. Later switch AI_PROVIDER to "openai" and add OPENAI_API_KEY.
AI_PROVIDER="local"
LOCAL_AI_BASE_URL="http://localhost:11434"
LOCAL_AI_MODEL="deepseek-r1:8b"
LOCAL_AI_KEEP_ALIVE="30m"
LOCAL_AI_NUM_CTX="4096"
LOCAL_AI_NUM_GPU="999"
LOCAL_AI_NUM_BATCH="512"
LOCAL_AI_NUM_PREDICT="4096"
LOCAL_AI_PAPER_NUM_PREDICT="2048"
LOCAL_AI_CANDIDATE_LIMIT="8"
LOCAL_RESEARCH_ENABLED="true"
LOCAL_RESEARCH_TIMEOUT_MS="900000"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
SEMANTIC_SCHOLAR_API_KEY=""
SEMANTIC_SCHOLAR_DISABLE_ANON="true"

# Optional configured product-data scraper endpoint.
# It should accept POST JSON: { "asin": "...", "affiliateLink": "..." }
# and return { title, brand, price, images, description }.
AMAZON_PRODUCT_API_ENDPOINT=""
AMAZON_PRODUCT_API_KEY=""
BRIGHT_DATA_API_KEY=""
BRIGHT_DATA_AMAZON_DATASET_ID="gd_l7q7dkf244hwjntr0"
BRIGHT_DATA_SYNC_TIMEOUT_MS="60000"

# Add a mailto value if Crossref politely asks for an identifying email.
CROSSREF_MAILTO=""
